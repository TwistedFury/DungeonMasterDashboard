@page "/campaigns"
@using DungeonMasterDashboard.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@inject IDbContextFactory<DMDbContext> DbFactory
@inject NavigationManager Nav
@rendermode InteractiveServer

<h2>Campaigns</h2>

<div style="margin-bottom: 1rem;">
    <button class="btn btn-primary" @onclick='(() => Nav.NavigateTo("/campaigns/new"))'>
        Create New Campaign
    </button>
</div>

@if (context.Campaigns == null)
{
    <p>Loading campaigns...</p>
}
else if (context.Campaigns.ToList().Count == 0)
{
    <p>No campaigns found.</p>
}
else
{
    <QuickGrid Class="table" Items="context.Campaigns">
        <PropertyColumn Property="Campaign => Campaign.Name" />
        <PropertyColumn Property="Campaign => Campaign.System" />
        <PropertyColumn Property="Campaign => Campaign.LastPlayed" />

        <TemplateColumn Context="Campaign">
            <a href="@($"campaigns/edit/{Campaign.Id}")">Edit</a> |
            <a href="@($"campaigns/details/{Campaign.Id}")">Details</a> |
            <a href="@($"campaigns/delete/{Campaign.Id}")">Delete</a>
        </TemplateColumn>
    </QuickGrid>
}

@code {
    private DMDbContext context = default!;

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
    }
}