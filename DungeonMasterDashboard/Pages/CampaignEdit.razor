@page "/campaigns/new"
@page "/campaigns/{Id:guid}"

@using System.ComponentModel.DataAnnotations
@using DungeonMasterDashboard.Models
@inject DungeonMasterDashboard.Services.ICampaignService Campaigns
@inject NavigationManager Nav

<h3>@pageTitle</h3>

<EditForm Model="form" OnValidSubmit="SaveCampaign">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Name</label>
        <InputText class="form-control" @bind-Value="form.Name" />
    </div>

    <div class="mb-3">
        <label class="form-label">System</label>
        <InputText class="form-control" @bind-Value="form.System" />
    </div>

    <div class="mb-3">
        <label class="form-label">Last Played</label>
        <InputDate class="form-control" @bind-Value="form.LastPlayed" />
    </div>

    <div class="mb-3">
        <label class="form-label">Notes</label>
        <InputTextArea class="form-control" @bind-Value="form.Notes" />
    </div>

    <button class="btn btn-primary" type="submit">Save</button>
    <button class="btn btn-secondary" type="button" @onclick="Cancel">
        Cancel
    </button>
</EditForm>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private CampaignForm form = new CampaignForm();
    private string pageTitle = "New Campaign";

    protected override async Task OnParametersSetAsync()
    {
        // If no Id is provided, creates a new campaign
        if (Id == null || Id == Guid.Empty)
        {
            pageTitle = "New Campaign";
            form = new CampaignForm();
            return;
        }

        // Otherwise, edit the existing campaign
        pageTitle = "Edit Campaign";

        var existingCampaign = await Campaigns.GetByIdAsync(Id.Value);

        if (existingCampaign == null)
        {
            // If campaign not found, returns to list
            Nav.NavigateTo("/campaigns");
            return;
        }

        form.Id = existingCampaign.Id;
        form.Name = existingCampaign.Name;
        form.System = existingCampaign.System;
        form.LastPlayed = existingCampaign.LastPlayed;
        form.Notes = existingCampaign.Notes;
    }

    private async Task SaveCampaign()
    {
        Campaign campaignToSave = new Campaign();

        // If editing, keeps the existing Id
        if (form.Id != Guid.Empty)
        {
            campaignToSave.Id = form.Id;
        }

        campaignToSave.Name = form.Name;
        campaignToSave.System = form.System;
        campaignToSave.LastPlayed = form.LastPlayed;
        campaignToSave.Notes = form.Notes;

        await Campaigns.SaveAsync(campaignToSave);

        Nav.NavigateTo("/campaigns");
    }

    private void Cancel()
    {
        Nav.NavigateTo("/campaigns");
    }

    private class CampaignForm
    {
        public Guid Id { get; set; }

        [Required]
        [StringLength(80)]
        public string Name { get; set; } = "";

        [Required]
        [StringLength(40)]
        public string System { get; set; } = "D&D 5e";

        public DateTime? LastPlayed { get; set; }

        [StringLength(500)]
        public string Notes { get; set; } = "";
    }
}